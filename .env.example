# =============================================================================
#  Provider selection (mini_workbuddy dual-provider adapter)
#
#  PROVIDER controls which model backend the mini harness / demo uses.
#    deepseek | anthropic | openai | openai-chat | offline | auto (default)
#  'auto' picks anthropic, then deepseek, then openai, then openai-chat, else offline.
#  'offline' needs no key and runs the deterministic mock provider.
# =============================================================================
# PROVIDER=deepseek

# ---- DeepSeek (recommended learning path; Anthropic-compatible endpoint) ----
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# ---- Anthropic (tool_use / tool_result) ----
ANTHROPIC_API_KEY=

# Model ID (required for anthropic)
MODEL_ID=claude-sonnet-4-6

# Base URL (optional, for Anthropic-compatible providers)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---- OpenAI (function_call / function_call_output, Responses API) ----
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1

# ---- OpenAI-compatible gateway (/v1/chat/completions, no SDK required) ----
# PROVIDER=openai-chat
# OPENAI_CHAT_BASE_URL=https://your-openai-compatible-gateway.example/v1
# OPENAI_CHAT_API_KEY=
# OPENAI_CHAT_MODEL=gpt-5.5

# =============================================================================
#  Anthropic-compatible providers
#
#  Provider         MODEL_ID              Base URL
#  ---------------  --------------------  -------------------
#  Anthropic        claude-sonnet-4-6     (default)
#  MiniMax          MiniMax-M2.5          https://api.minimax.io/anthropic
#  GLM (Zhipu)      glm-5                https://api.z.ai/api/anthropic
#  Kimi (Moonshot)  kimi-k2.5            https://platform.moonshot.ai/anthropic
#  DeepSeek         deepseek-v4-pro      https://api.deepseek.com/anthropic
# =============================================================================

# ---- International ----

# MiniMax          https://www.minimax.io
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# MODEL_ID=MiniMax-M2.5

# GLM (Zhipu)      https://z.ai
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# MODEL_ID=glm-5

# Kimi (Moonshot)  https://platform.moonshot.ai
# ANTHROPIC_BASE_URL=https://platform.moonshot.ai/anthropic
# MODEL_ID=kimi-k2.5

# DeepSeek         https://platform.deepseek.com
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL_ID=deepseek-v4-pro
